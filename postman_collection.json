{
  "info": {
    "_postman_id": "c8d6e72f-0db2-4fb5-a1c6-2ec6ea827001",
    "name": "Gestion Contratacion API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "tokenReclutador", "value": "" },
    { "key": "tokenCandidato", "value": "" },
    { "key": "vacanteId", "value": "1" },
    { "key": "postulacionId", "value": "1" },
    { "key": "candidatoId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Reclutador",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"reclutador1\",\n  \"password\": \"Clave12345\",\n  \"email\": \"reclutador1@mail.com\",\n  \"role\": \"reclutador\"\n}"
            }
          }
        },
        {
          "name": "Register Candidato",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"candidato1\",\n  \"password\": \"Clave12345\",\n  \"email\": \"candidato1@mail.com\",\n  \"role\": \"candidato\"\n}"
            }
          }
        },
        {
          "name": "Login Reclutador",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"reclutador1\",\n  \"password\": \"Clave12345\"\n}"
            }
          }
        },
        {
          "name": "Login Candidato",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"candidato1\",\n  \"password\": \"Clave12345\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Vacantes",
      "item": [
        {
          "name": "Crear Vacante (Reclutador)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/vacantes/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Backend Python\",\n  \"descripcion\": \"Experiencia en DRF\",\n  \"area\": \"TI\",\n  \"fecha_limite\": \"2030-01-31\",\n  \"estado\": \"activa\"\n}"
            }
          }
        },
        {
          "name": "Listar Vacantes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/vacantes/"
          }
        },
        {
          "name": "Editar Vacante",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/vacantes/{{vacanteId}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"pausada\"\n}"
            }
          }
        },
        {
          "name": "Eliminar Vacante",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/vacantes/{{vacanteId}}/"
          }
        }
      ]
    },
    {
      "name": "Candidatos",
      "item": [
        {
          "name": "Crear Candidato",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/candidatos/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana Perez\",\n  \"correo\": \"ana.perez@mail.com\",\n  \"telefono\": \"3001234567\",\n  \"perfil_profesional\": \"Desarrolladora Python\",\n  \"hoja_vida\": \"https://mihojadevida.com/ana\"\n}"
            }
          }
        },
        {
          "name": "Listar Candidatos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/candidatos/"
          }
        },
        {
          "name": "Editar Candidato",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/candidatos/{{candidatoId}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telefono\": \"3007654321\"\n}"
            }
          }
        },
        {
          "name": "Eliminar Candidato",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/candidatos/{{candidatoId}}/"
          }
        }
      ]
    },
    {
      "name": "Postulaciones",
      "item": [
        {
          "name": "Crear Postulacion (Candidato)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenCandidato}}" }
            ],
            "url": "{{baseUrl}}/api/postulaciones/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vacante\": {{vacanteId}}\n}"
            }
          }
        },
        {
          "name": "Listar Postulaciones",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/postulaciones/"
          }
        },
        {
          "name": "Actualizar Estado Postulacion (Reclutador)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenReclutador}}" }
            ],
            "url": "{{baseUrl}}/api/postulaciones/{{postulacionId}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"aceptada\"\n}"
            }
          }
        }
      ]
    }
  ]
}
